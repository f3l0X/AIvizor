# --- LLM ---
# gemini | claude | mock
LLM_PROVIDER=mock
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Modelos por defecto (opcional)
# gemini-2.5-flash tiene free tier; gemini-2.0-flash ya no (devuelve limit:0).
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Database ---
POSTGRES_USER=aivizor
POSTGRES_PASSWORD=aivizor
POSTGRES_DB=aivizor
DATABASE_URL=postgresql+psycopg://aivizor:aivizor@db:5432/aivizor
# Aplicar las migraciones de Alembic al arrancar el backend. Cómodo en dev; en
# producción se suele desactivar (=false) y aplicarlas como paso de despliegue.
AUTO_MIGRATE=true

# --- Backend ---
# Lista separada por comas. :3000 = frontend dev (Docker); :3001 = build de
# producción local (ver docs/DEMO.md).
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Endurecimiento HTTP (Fase 7.7) ---
# Tamaño máximo del body (bytes). 413 por encima. El payload legítimo más grande
# (~80 KB) cabe de sobra en el default de 1 MB.
MAX_BODY_BYTES=1048576
# Rate limiting en memoria por IP (429 + Retry-After al exceder). Detrás de un
# proxy inverso habría que derivar la IP de X-Forwarded-For (ver security.md).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_LLM_PER_MINUTE=30

# --- Auth (Fase 7.2) ---
# Secreto de firma JWT. CÁMBIALO en producción (mín. 32 bytes). Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me-in-production-please
JWT_EXPIRE_MINUTES=1440
# Cookie de sesión. secure=true solo bajo HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Admin inicial: si ambos están definidos, se siembra al arrancar (idempotente).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- BYOK (Fase 7.3) ---
# Clave Fernet para cifrar en reposo las API keys que aporta cada usuario.
# CÁMBIALA en producción y guárdala fuera del repo. Generar con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=x9clRcUs9p0gQoMG8iP3G8OctC3rfU5bmDzfIhyBpmQ=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
